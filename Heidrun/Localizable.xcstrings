    },
    "Adds a Window → Protocol Console item that shows every Hotline transaction sent to and received from any open connection. Unknown transaction IDs are flagged red — useful for spotting non-standard server dialects. New connections opened after this toggle is changed pick up the new state." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügt unter „Fenster“ → „Protokollkonsole“ einen Eintrag hinzu, der jede an eine offene Verbindung gesendete und von ihr empfangene Hotline-Transaktion anzeigt. Unbekannte Transaktions-IDs werden rot markiert – nützlich, um nicht standardkonforme Server-Dialekte zu erkennen. Verbindungen, die nach dem Ändern dieser Option geöffnet werden, übernehmen den neuen Zustand."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「ウインドウ」→「プロトコルコンソール」の項目を追加し、開いている接続との間で送受信されるすべてのHotlineトランザクションを表示します。不明なトランザクションIDは赤で表示され、非標準のサーバ方言を見つけるのに役立ちます。この設定を変更した後に開いた接続から、新しい状態が適用されます。"
          }
        }
      }
    },
    "Adds a system line in public chat when someone connects or disconnects." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügt eine Systemzeile im öffentlichen Chat ein, wenn jemand verbunden oder getrennt wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adds a system line in public chat when someone connects or disconnects."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "誰かが接続または切断したときに、公開チャットにシステム行を追加します。"
          }
        }
      }
    },
    "Affects the user list, file list, chat transcript, and other written content. Settings windows themselves stay at the macOS default." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Betrifft die Benutzerliste, Dateiliste, das Chat-Transkript und andere geschriebene Inhalte. Einstellungsfenster selbst bleiben auf der macOS-Standardgröße."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Affects the user list, file list, chat transcript, and other written content. Settings windows themselves stay at the macOS default."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ユーザーリスト・ファイルリスト・チャット記録などの文字コンテンツに影響します。設定ウインドウ自体はmacOSの標準サイズのままです。"
          }
        }
      }
    },
