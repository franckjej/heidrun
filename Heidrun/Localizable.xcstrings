      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drücke ↑ im Chat-Eingabefeld, um frühere Nachrichten abzurufen — plus ein Menü mit letzten Nachrichten neben der Senden-Schaltfläche. Wird nur im Speicher gehalten und beim Trennen gelöscht."
          }
        },
        "ja" : {
          "stringUnit" : {
