    "Uploads and downloads will appear here while they're running and after they finish." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uploads und Downloads erscheinen hier, während sie laufen und nachdem sie abgeschlossen sind."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アップロードとダウンロードは、実行中および完了後にここに表示されます。"
          }
        }
      }
    },
